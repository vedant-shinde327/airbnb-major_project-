<% layout("/layouts/boilerplate") %>

    <div id="filters">

        <a href="/listings" class="text-decoration-none">
            <div class="filter <%= selectedCategory === "" ? " active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-border-all"></i>
                </div>
                <p>All</p>
            </div>
        </a>

        <a href="/listings?category=Trending" class="text-decoration-none">
            <div class="filter <%= selectedCategory === " Trending" ? "active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-fire"></i>
                </div>
                <p>Trending</p>
            </div>
        </a>

        <a href="/listings?category=Rooms" class="text-decoration-none">
            <div class="filter <%= selectedCategory === " Rooms" ? "active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-bed"></i>
                </div>
                <p>Rooms</p>
            </div>
        </a>

        <a href="/listings?category=Iconic%20Cities" class="text-decoration-none">
            <div class="filter <%= selectedCategory === " Iconic Cities" ? "active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-city"></i>
                </div>
                <p>Iconic Cities</p>
            </div>
        </a>

        <a href="/listings?category=Mountains" class="text-decoration-none">
            <div class="filter <%= selectedCategory === " Mountains" ? "active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-city"></i>
                </div>
                <p>Mountains</p>
            </div>
        </a>

        <a href="/listings?category=Amazing%20Pools" class="text-decoration-none">
            <div class="filter <%= selectedCategory === " Amazing Pools" ? "active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-city"></i>
                </div>
                <p>Amazing Pools</p>
            </div>
        </a>

        <a href="/listings?category=Camping" class="text-decoration-none">
            <div class="filter <%= selectedCategory === " Camping" ? "active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-city"></i>
                </div>
                <p>Camping</p>
            </div>
        </a>

        <a href="/listings?category=Farms" class="text-decoration-none">
            <div class="filter <%= selectedCategory === " Farms" ? "active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-city"></i>
                </div>
                <p>Farms</p>
            </div>
        </a>

        <a href="/listings?category=Arctic" class="text-decoration-none">
            <div class="filter <%= selectedCategory === " Arctic" ? "active-filter" : "" %>">
                <div>
                    <i class="fa-solid fa-city"></i>
                </div>
                <p>Arctic</p>
            </div>
        </a>

        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">
                    Display total after taxes
                </label>
            </div>
        </div>

    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mt-3">

        <% for (const listing of allListing) { const imageUrl=listing.image.url.replace( "/upload"
            , "/upload/w_500,h_350,c_fill,f_auto,q_auto" ); const formattedPrice=listing.price.toLocaleString("en-IN");
            %>

            <a href="/listings/<%= listing._id %>" class="listing">

                <div class="card col listing-card">
                    <div class="card h-100 listing-card">

                        <img src="<%= imageUrl %>" class="card-img-top" style="height:16rem;object-fit:cover;"
                            alt="listing_image">

                        <div class="card-img-overlay"></div>

                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= listing.title %>
                                </b>
                                <br>
                                <span class="listing-price" data-price="<%= listing.price %>">
                                    ₹<%= formattedPrice %>
                                </span>

                                <i class="tax-info" style="display: none;">
                                    (Incl. 18% GST)
                                </i>
                            </p>
                        </div>

                    </div>
                </div>

            </a>

            <% } %>

    </div>

    <script>
        const GST_RATE = 0.18;

        const taxSwitch = document.getElementById("switchCheckDefault");
        const prices = document.querySelectorAll(".listing-price");
        const taxInfo = document.querySelectorAll(".tax-info");

        taxSwitch.addEventListener("change", () => {
            const showGST = taxSwitch.checked;

            prices.forEach((priceElement) => {
                const originalPrice = Number(priceElement.dataset.price);

                const displayPrice = showGST
                    ? Math.round(originalPrice * (1 + GST_RATE))
                    : originalPrice;

                priceElement.textContent =
                    `₹${displayPrice.toLocaleString("en-IN")}`;
            });

            taxInfo.forEach((info) => {
                info.style.display = showGST ? "inline" : "none";
            });
        });
    </script>