<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-3">
       <h3><b><%= listing.title%></b> <br></h3>
</div>
  <div class="card col-6 offset-3 show-card listing-card">
    <img src="<%= listing.image.url %>" class="card-img-top show-img mb-3" alt="listing_image"/>
    <div class="card-body ">
      <p class="card-text">
        <b><%= listing.title%></b> <br>
        <%= listing.description%> <br>
        &#8377;<%= listing.price.toLocaleString("en-IN")%> <br>
        <%= listing.location%> <br>
        <%= listing.country%>
    </p>
    </div>
  </div>
<div class="btns">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark add-btn col-1 offset-3 mb-3">Edit </a>

    <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
    <button class="btn btn-dark  offset-2 mb-3">Delete</button>
  </form>
</div>

  <div class="col-8 offset-3">
    <hr>
    <H4>Leave a Review</H4>
    <form action="/listings/<%= listing._id%>/reviews" method="post" novalidate class="needs-validation">
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>
        <input type="range" name="review[rating]" min="1" max="5" id="rating" class="form-range" required>
      </div>

      <div class="mb-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea name="review[comment]" rows="5" cols="30" id="comment" class="form-control " required></textarea>

        <div class="invalid-feedback">
          Please add some comments for review
        </div>
      </div>
      <button class="btn btn-outline-dark mb-3">Submit</button>
    </form>
    <hr>

    <p><b>All Reviews</b></p>
    <div class="row">
    <% for (review of listing.reviews) { %>
      <div class="card col-5 ms-3 mb-3">
        <div class="card-body">
          <h5 class="card-title">title</h5>
          <p class="card-text"> <%= review.comment%></p>
          <p class="card-text"><%= review.rating %> star</p>
          <h6></h6>
        </div>
        <form action="/listings/<%= listing._id%>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="post">
          <button class="btn btn-sm btn-dark">Delete</button>
        </form>
      </div>
    <% } %>
    </div>
    
  </div>
</div>